---
import workshop from "../data/workshop.json";
import SectionHeading from "./SectionHeading.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const stats = [
  { value: workshop.instructor.sessions, label: "EOS Sessions" },
  { value: workshop.instructor.yearsExperience, label: "Years Leading" },
  { value: "Expert", label: "EOS Implementer" },
];
---

<section id="instructor" class="bg-eos-light py-16 md:py-24">
  <div class="mx-auto max-w-5xl px-4">
    <div class="flex flex-col items-center">
      <SectionHeading>Your Instructor</SectionHeading>
    </div>

    <div class="mt-12 flex flex-col items-center gap-8 md:flex-row md:items-start md:gap-12">
      <div class="shrink-0">
        <div class="h-64 w-64 overflow-hidden rounded-2xl bg-gray-200 shadow-lg">
          <img
            src={`${base}${workshop.instructor.photo}`}
            alt={`${workshop.instructor.name} - ${workshop.instructor.title}`}
            class="h-full w-full object-cover"
            loading="lazy"
            onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=\'flex h-full w-full items-center justify-center bg-eos-dark text-white text-4xl font-bold\'>RG</div>'"
          />
        </div>
      </div>

      <div class="text-center md:text-left">
        <h3 class="text-2xl font-bold text-eos-dark">{workshop.instructor.name}</h3>
        <p class="mt-1 font-medium text-eos-orange">{workshop.instructor.title}</p>
        <p class="mt-4 text-lg leading-relaxed text-gray-600">
          {workshop.instructor.bio}
        </p>

        <ol class="mt-6 space-y-4 text-left text-gray-700 leading-relaxed">
          {workshop.instructor.traits.map((trait, i) => (
            <li class="flex gap-3">
              <span class="font-semibold text-eos-dark shrink-0">{i + 1}.</span>
              <p><span class="font-semibold text-eos-dark">{trait.label}</span> – {trait.description}</p>
            </li>
          ))}
        </ol>

        <div class="mt-6 flex flex-wrap justify-center gap-6 md:justify-start">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="text-2xl font-bold text-eos-orange">{stat.value}</div>
              <div class="text-xs font-medium uppercase tracking-wide text-gray-500">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
