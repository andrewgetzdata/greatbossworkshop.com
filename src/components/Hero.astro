---
import workshop from "../data/workshop.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section id="hero" class="relative overflow-hidden bg-gradient-to-br from-eos-dark to-eos-dark-light py-20 text-white md:py-32">
  <svg class="absolute inset-0 h-full w-full opacity-[0.06]" aria-hidden="true">
    <defs>
      <pattern id="bang-pattern" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse" patternTransform="rotate(12)">
        <circle cx="40" cy="40" r="18" fill="#FF7900"/>
        <rect x="38" y="30" width="4" height="11" rx="0.5" fill="#142233"/>
        <circle cx="40" cy="46" r="2" fill="#142233"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#bang-pattern)"/>
  </svg>

  <div class="relative mx-auto max-w-5xl px-4 text-center">
    <img
      src={`${base}/images/brand/gb-horizontal-white.png`}
      alt="Great Boss Workshop"
      class="mx-auto mb-10 h-20 w-auto md:h-28"
    />

    <h1 class="text-3xl font-extrabold uppercase leading-tight tracking-tight md:text-5xl">
      Elevate Your Leadership & Maximize Your Team Energy
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300 md:text-xl">
      Work along side an expert EOS® Implementer® and other leaders to master the
      leadership and management practices that build accountable, high-performing teams.
    </p>

    <div id="hero-badge" class="mt-4 inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-medium backdrop-blur-sm">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <span id="hero-dates">Loading next workshop...</span>
    </div>

    <div class="mt-8">
      <a
        href="#pricing"
        class="inline-block rounded-lg bg-eos-orange px-8 py-4 text-lg font-bold text-white shadow-lg transition hover:bg-eos-orange-light hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-eos-orange focus:ring-offset-2 focus:ring-offset-eos-dark"
        data-cta="hero"
      >
        Reserve Your Seat
      </a>
    </div>

  </div>
</section>

<script is:inline>
  document.querySelectorAll('[data-cta="hero"]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (window.posthog) window.posthog.capture('cta_clicked', { source: 'hero' });
    });
  });

  // Fetch next available session for hero badge
  fetch('/api/list-sessions')
    .then(function(res) { return res.json(); })
    .then(function(data) {
      var next = data.sessions && data.sessions.find(function(s) { return s.status === 'on_sale'; });
      var el = document.getElementById('hero-dates');
      if (next && el) {
        var locationText = next.location || '';
        el.textContent = 'Next workshop: ' + next.dateDisplay + (locationText ? ' \u00B7 ' + locationText : '');
      } else if (el) {
        el.textContent = 'New dates coming soon';
      }
    })
    .catch(function() {
      var el = document.getElementById('hero-dates');
      if (el) el.textContent = 'New dates coming soon';
    });
</script>
