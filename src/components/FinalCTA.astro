---
import workshop from "../data/workshop.json";

const priceFormatted = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: workshop.pricing.currency,
  minimumFractionDigits: 0,
}).format(workshop.pricing.basePrice);
---

<section id="final-cta" class="bg-gradient-to-br from-eos-orange to-eos-orange-light py-16 text-white md:py-24">
  <div class="mx-auto max-w-3xl px-4 text-center">
    <h2 class="text-3xl font-extrabold uppercase tracking-wide md:text-4xl">Ready to Become a Great Boss?</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-white/80">
      Join {workshop.instructor.name} and fellow leaders for a day that will transform
      how you lead, manage, and develop your team.
    </p>

    <div class="mt-8">
      <a
        href="#pricing"
        class="inline-block rounded-lg bg-eos-dark px-8 py-4 text-lg font-bold text-white shadow-lg transition hover:bg-eos-dark-light hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-eos-orange"
        data-cta="final"
      >
        Reserve Your Seat — Starting at {priceFormatted}
      </a>
    </div>

    <p class="mt-4 text-sm text-white/60">
      Full refund available 14+ days before the workshop
    </p>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('[data-cta="final"]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (window.posthog) window.posthog.capture('cta_clicked', { source: 'final_cta' });
    });
  });
</script>
