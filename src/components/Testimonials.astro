---
import workshop from "../data/workshop.json";
---

<section id="testimonials" class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-5xl px-4">
    <h2 class="text-center text-3xl font-bold text-eos-navy md:text-4xl">What Past Attendees Say</h2>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {workshop.testimonials.map((testimonial) => (
        <div class="flex flex-col rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
          <!-- Quote icon -->
          <svg class="mb-4 h-8 w-8 text-eos-teal/30" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
          </svg>

          <blockquote class="flex-1 text-gray-700 italic leading-relaxed">
            "{testimonial.quote}"
          </blockquote>

          <div class="mt-4 border-t border-gray-100 pt-4">
            <p class="font-semibold text-eos-navy">{testimonial.author}</p>
            <p class="text-sm text-gray-500">{testimonial.title}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Placeholder note for future video testimonials -->
    <!-- TODO: Add video testimonials with videoUrl field in workshop.json -->
  </div>
</section>
