---
import Layout from "../layouts/Layout.astro";
import workshop from "../data/workshop.json";
---

<Layout title="You're Registered! | Great Boss Workshop">
  <section class="flex min-h-[70vh] items-center justify-center bg-eos-light py-16">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <!-- Checkmark -->
      <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-green-100">
        <svg class="h-10 w-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="mt-6 text-3xl font-bold text-eos-dark md:text-4xl">You're Registered!</h1>
      <p class="mt-3 text-lg text-gray-600">
        Welcome to the {workshop.title}. We're excited to have you join us.
      </p>

      <!-- Workshop Details -->
      <div class="mt-8 rounded-xl border border-gray-200 bg-white p-6 text-left shadow-sm">
        <h2 class="text-lg font-bold text-eos-dark">Workshop Details</h2>
        <dl class="mt-4 space-y-3 text-gray-700">
          <div class="flex gap-3">
            <dt class="font-medium text-gray-500">Date</dt>
            <dd>{workshop.dateDisplay}</dd>
          </div>
          <div class="flex gap-3">
            <dt class="font-medium text-gray-500">Time</dt>
            <dd>{workshop.time}</dd>
          </div>
          <div class="flex gap-3">
            <dt class="font-medium text-gray-500">Location</dt>
            <dd>
              <a href={workshop.location.mapsUrl} target="_blank" rel="noopener noreferrer" class="text-eos-orange hover:underline">
                {workshop.location.address}, {workshop.location.city}, {workshop.location.state} {workshop.location.zip}
              </a>
            </dd>
          </div>
          <div class="flex gap-3">
            <dt class="font-medium text-gray-500">Instructor</dt>
            <dd>{workshop.instructor.name}, {workshop.instructor.title}</dd>
          </div>
        </dl>
      </div>

      <!-- What's Next -->
      <div class="mt-8 text-left">
        <h2 class="text-lg font-bold text-eos-dark">What's Next</h2>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-eos-orange text-xs font-bold text-white">1</span>
            <span class="text-gray-700"><strong>Check your email</strong> for a confirmation receipt from Stripe.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-eos-orange text-xs font-bold text-white">2</span>
            <span class="text-gray-700"><strong>Calendar invite</strong> — you'll receive a calendar invite with all the details shortly.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-eos-orange text-xs font-bold text-white">3</span>
            <span class="text-gray-700"><strong>Come ready to learn</strong> — bring an open mind. All materials, workbooks, and lunch are provided.</span>
          </li>
        </ul>
      </div>

      <a href="/" class="mt-8 inline-block text-eos-orange hover:underline">
        &larr; Back to workshop details
      </a>
    </div>
  </section>
</Layout>

<script is:inline>
  if (window.posthog) {
    var params = new URLSearchParams(window.location.search);
    window.posthog.capture('payment_completed', {
      session_id: params.get('session_id')
    });
  }
</script>
